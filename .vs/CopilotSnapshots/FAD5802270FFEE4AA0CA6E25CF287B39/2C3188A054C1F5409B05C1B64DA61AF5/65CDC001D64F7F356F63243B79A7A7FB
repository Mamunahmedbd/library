    public partial class Login : Form
    {
        public Login()
        {
            InitializeComponent();

        }

        private void btnLogin_Click(object sender, EventArgs e)
        {
            string sql = "SELECT * FROM dbo.AdminList WHERE UserName = @user AND Password = @pwd";

            using (var cmd = new System.Data.SqlClient.SqlCommand(sql))
            {
                cmd.Parameters.AddWithValue("@user", this.tbUserName.Text);
                cmd.Parameters.AddWithValue("@pwd", this.tbPwd.Text);

                DataSet ds = SQLHelper.GetData(cmd);

                if (ds != null && ds.Tables.Count > 0 && ds.Tables[0].Rows.Count > 0)
                {
                    this.Hide();
                    MainForm mForm = new MainForm();
                    mForm.Show();
                }
                else
                {
                    MessageBox.Show("The user info is error.", "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }
        }

        private void btnExit_Click(object sender, EventArgs e)
        {
            Application.Exit();
        }

